{
  "manifest_version": "0.3",
  "name": "intervals-mcp",
  "version": "2.0.0",
  "display_name": "intervals.icu — Triathlon Training",
  "description": "Connects Claude to your intervals.icu training data via the intervals-mcp Cloudflare Worker. Deploy your own Worker from https://github.com/psca/intervals.icu-server first.",
  "icon": "icon.png",
  "author": {
    "name": "intervals.icu Triathlon Coach"
  },

  "user_config": {
    "INTERVALS_MCP_URL": {
      "type": "string",
      "title": "Worker URL",
      "description": "The deployed Worker URL, e.g. https://intervals-mcp.your-account.workers.dev/mcp",
      "required": true
    },
    "INTERVALS_MCP_SECRET": {
      "type": "string",
      "title": "Worker Secret",
      "description": "The WORKER_SECRET set on your Cloudflare Worker via wrangler secret put WORKER_SECRET",
      "sensitive": true,
      "required": true
    }
  },

  "server": {
    "type": "python",
    "entry_point": "server/run.py",
    "mcp_config": {
      "command": "npx",
      "args": ["mcp-remote", "${user_config.INTERVALS_MCP_URL}"],
      "env": {
        "INTERVALS_MCP_URL": "${user_config.INTERVALS_MCP_URL}",
        "INTERVALS_MCP_SECRET": "${user_config.INTERVALS_MCP_SECRET}"
      }
    }
  }
}
